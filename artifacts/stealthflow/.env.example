# StealthFlow environment variables
# Copy to .env and fill in your values

# Your wallet private key (without 0x prefix)
# NEVER commit .env to version control
PRIVATE_KEY=your_private_key_here

# Fhenix Helium RPC (default: https://api.helium.fhenix.zone)
FHENIX_RPC_URL=https://api.helium.fhenix.zone

# Base Sepolia RPC (alternative network)
BASE_SEPOLIA_RPC_URL=https://sepolia.base.org

# ── Vercel deployment ──────────────────────────────────────────────────────────
# URL of the deployed API server (no trailing slash).
# Set this in the Vercel dashboard under Environment Variables.
VITE_API_URL=https://your-api-server.vercel.app
